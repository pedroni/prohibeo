{
  "name": "prohibeo",
  "private": true,
  "version": "0.1.0",
  "description": "Prohibeo Chrome extension",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "generate:branding": "node scripts/generate-branding.mjs",
    "dev": "npm run generate:branding && vite",
    "build:debug": "npm run generate:branding && tsc -b && vite build --mode debug",
    "build": "npm run generate:branding && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "site:dev": "npm run generate:branding && npm --prefix site run dev",
    "site:build": "npm run generate:branding && npm --prefix site run build",
    "site:preview": "npm --prefix site run preview"
  },
  "dependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "tldts": "^7.0.25"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wrangler": "^4.76.0"
  }
}
