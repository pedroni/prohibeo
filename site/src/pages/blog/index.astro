---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (left, right) => right.data.publishDate.valueOf() - left.data.publishDate.valueOf(),
);
---

<BaseLayout
  title="Prohibeo Blog"
  description="Product updates, focus workflows, and launch notes for Prohibeo."
  pathname="/blog/"
>
  <main class="border-t border-black dark:border-neutral-700">
    <div class="max-w-3xl px-6 py-8 md:px-8 md:py-10">
      <h1 class="mb-3 text-[2rem] leading-none font-bold tracking-[-0.04em] md:text-[2.75rem]">
        Prohibeo Blog
      </h1>
      <p class="text-base leading-7 text-neutral-700 dark:text-neutral-400">
        A lightweight MDX-powered blog for release notes, product updates, and focus
        ideas that support the extension.
      </p>
    </div>
    <div class="grid grid-cols-1 pl-px pt-px">
      {
        posts.map((post) => (
          <article class="-ml-px -mt-px border border-black p-6 dark:border-neutral-700 md:p-8">
            <time class="block text-sm text-neutral-600 dark:text-neutral-400" datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('en-US', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
              })}
            </time>
            <h3 class="mt-3 mb-3 text-lg font-semibold">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p class="max-w-2xl text-sm leading-6 text-neutral-700 dark:text-neutral-400">{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </main>
</BaseLayout>
