---
import { formatBlogPublishDate, getPublishedBlogPosts } from "../../blog";
import GridBox from "../../components/GridBox.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getPublishedBlogPosts();
---

<BaseLayout
    title="Prohibeo Blog | Notes on cleaner browsing"
    description="Short essays and practical guides on focus, mixed-use sites, and less noisy browsing."
    pathname="/blog/"
>
    <main>
        <div class="max-w-3xl px-6 py-8 md:px-8 md:py-10">
            <SectionTitle as="h1" size="lg">Prohibeo Blog</SectionTitle>
            <p class="text-base leading-7 text-muted-foreground">
                Short essays and practical guides on focus, mixed-use sites,
                and better defaults for the browser.
            </p>
        </div>
        <div class="grid grid-cols-1">
            {
                posts.map((post) => (
                    <GridBox as="article">
                        <time
                            class="block text-sm text-muted-foreground"
                            datetime={post.data.publishDate.toISOString()}
                        >
                            {formatBlogPublishDate(post.data.publishDate)}
                        </time>
                        <h3 class="mt-3 mb-3 text-lg font-semibold">
                            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                        </h3>
                        <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
                            {post.data.description}
                        </p>
                    </GridBox>
                ))
            }
        </div>
    </main>
</BaseLayout>
