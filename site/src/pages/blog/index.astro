---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GridBox from "../../components/GridBox.astro";
import SectionTitle from "../../components/SectionTitle.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (left, right) =>
        right.data.publishDate.valueOf() - left.data.publishDate.valueOf(),
);
---

<BaseLayout
    title="Prohibeo Blog"
    description="Practical focus tips, calmer-browser workflows, and product updates from Prohibeo."
    pathname="/blog/"
>
    <main>
        <div class="max-w-3xl px-6 py-8 md:px-8 md:py-10">
            <SectionTitle as="h1" size="lg">Prohibeo Blog</SectionTitle>
            <p class="text-base leading-7 text-muted-foreground">
                Practical ideas for a calmer browser: focus tips,
                distraction-proof workflows, and product updates from Prohibeo.
            </p>
        </div>
        <div class="grid grid-cols-1">
            {
                posts.map((post) => (
                    <GridBox as="article">
                        <time
                            class="block text-sm text-muted-foreground"
                            datetime={post.data.publishDate.toISOString()}
                        >
                            {post.data.publishDate.toLocaleDateString("en-US", {
                                month: "long",
                                day: "numeric",
                                year: "numeric",
                            })}
                        </time>
                        <h3 class="mt-3 mb-3 text-lg font-semibold">
                            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                        </h3>
                        <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
                            {post.data.description}
                        </p>
                    </GridBox>
                ))
            }
        </div>
    </main>
</BaseLayout>
