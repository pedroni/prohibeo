---
import { Button } from "@ui/Button";
import { formatBlogPublishDate, getPublishedBlogPosts } from "../blog";
import ExtensionPreview from "../components/ExtensionPreview.astro";
import GridBox from "../components/GridBox.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionTitle from "../components/SectionTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const chromeLogoUrl = "/chrome-logo.svg";

const recentPosts = (await getPublishedBlogPosts()).slice(0, 3);
---

<BaseLayout
    title="Prohibeo | Less noise. More focus."
    description="Block distracting sites, hide noisy page sections, and run schedules that keep Chrome calm."
    pathname="/"
>
    <main>
        <section>
            <div class="grid grid-cols-1 md:grid-cols-2">
                <div
                    class="border-border px-6 py-10 md:border-r md:border-b-0 md:px-8 md:py-12"
                >
                    <span
                        class="inline-flex border border-border px-3 py-1 text-xs font-bold uppercase tracking-[0.08em]"
                    >
                        Less noise. More focus.
                    </span>
                    <h1 class="mt-6 text-5xl font-bold md:text-6xl">
                        Block distractions without turning the web into a fight.
                    </h1>
                    <p
                        class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground"
                    >
                        Block what pulls you away. Hide what you do not need.
                        Keep the useful part of the web, privately in Chrome.
                    </p>
                    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                        <Button
                            href="https://chromewebstore.google.com/category/extensions"
                            size="lg"
                        >
                            Add to Chrome
                            <img alt="" class="h-4 w-4" src={chromeLogoUrl} />
                        </Button>
                    </div>
                    <p
                        class="mt-4 max-w-2xl text-sm leading-6 text-muted-foreground"
                    >
                        Free to use. No account. Runs locally in Chrome.
                    </p>
                </div>
                <ExtensionPreview />
            </div>
        </section>

        <section id="who-its-for" class="border-t border-border">
            <SectionIntro>
                <SectionTitle>Three clean controls</SectionTitle>
                <p class="text-base leading-7 text-muted-foreground">
                    Prohibeo does three things well: block the sites that derail
                    you, strip noise from pages you still need, and run on rules
                    you can actually live with.
                </p>
            </SectionIntro>
            <div class="grid grid-cols-1 pl-px pt-px md:grid-cols-3">
                <GridBox as="article">
                    <h3 class="mb-4 text-lg font-semibold">Block any site</h3>
                    <p class="text-sm leading-6 text-muted-foreground">
                        Use a full block when a site rarely helps and usually
                        steals time. Make the decision once and move on.
                    </p>
                </GridBox>
                <GridBox as="article">
                    <h3 class="mb-4 text-lg font-semibold">Hide the noisy parts</h3>
                    <p class="text-sm leading-6 text-muted-foreground">
                        Keep the page. Remove the comments, feeds,
                        recommendations, and sidebars that pull you off course.
                    </p>
                </GridBox>
                <GridBox as="article">
                    <h3 class="mb-4 text-lg font-semibold">Block on your terms</h3>
                    <p class="text-sm leading-6 text-muted-foreground">
                        Run rules all day, on a schedule, or just for now. Keep
                        your setup strict when it should be, and light when it
                        should not.
                    </p>
                </GridBox>
            </div>
        </section>

        <section class="border-t border-border" id="install">
            <div class="px-6 py-8 md:px-8 md:py-20">
                <div class="grid gap-4">
                    <div class="mx-auto text-center max-w-3xl">
                        <SectionTitle
                            >Access what matters. Hide what does not.</SectionTitle
                        >
                        <p class="mb-6 text-base leading-7 text-muted-foreground">
                            Keep useful sites usable and distracting loops out of
                            the way.
                        </p>
                        <Button
                            href="https://chromewebstore.google.com/category/extensions"
                            size="lg"
                        >
                            Add to Chrome
                            <img alt="" class="h-4 w-4" src={chromeLogoUrl} />
                        </Button>
                    </div>

                </div>
            </div>
        </section>

        <section class="border-t border-border" id="privacy">
            <div class="px-6 py-8 md:px-8 md:py-10">
                <div class="grid gap-4">
                    <div class="max-w-3xl">
                        <SectionTitle>Private by design</SectionTitle>
                        <p class="text-base leading-7 text-muted-foreground">
                            Your rules stay in Chrome. No account. No analytics.
                            No app data leaving the extension for core features.
                        </p>
                    </div>
                    <ul
                        class="list-disc space-y-3 pl-5 text-sm leading-6 text-muted-foreground"
                    >
                        <li>Rules are stored locally in Chrome</li>
                        <li>No accounts, logins, or cloud sync</li>
                        <li>No analytics or tracking</li>
                        <li>No data leaves the extension for app features</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="border-t border-border">
            <SectionIntro>
                <SectionTitle>Notes</SectionTitle>
                <p class="text-base leading-7 text-muted-foreground">
                    Short guides on cleaner browsing, mixed-use sites, and
                    better defaults for focus.
                </p>
            </SectionIntro>
            {
                recentPosts.length > 0 && (
                    <div class="grid grid-cols-1 pl-px pt-px md:grid-cols-3">
                        {recentPosts.map((post) => (
                            <GridBox as="article">
                                <time
                                    class="block text-sm text-muted-foreground"
                                    datetime={post.data.publishDate.toISOString()}
                                >
                                    {formatBlogPublishDate(
                                        post.data.publishDate,
                                    )}
                                </time>
                                <h3 class="mt-3 mb-3 text-lg font-semibold">
                                    <a href={`/blog/${post.id}/`}>
                                        {post.data.title}
                                    </a>
                                </h3>
                            </GridBox>
                        ))}
                    </div>
                )
            }
        </section>
    </main>
</BaseLayout>
