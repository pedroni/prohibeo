---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Button } from "@ui/Button";
import GridBox from "../components/GridBox.astro";
import InlineCode from "../components/InlineCode.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionTitle from "../components/SectionTitle.astro";

const latestPost = (await getCollection("blog", ({ data }) => !data.draft))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
    .at(0);
---

<BaseLayout
    title="Prohibeo | Block distracting sites and reclaim your focus"
    description="Prohibeo is a Chrome extension for blocking distracting websites, scheduling focus time, and hiding the parts of a page that steal your attention."
    pathname="/"
>
    <main>
        <section>
            <div class="grid grid-cols-1 md:grid-cols-2">
                <div
                    class="border-b border-foreground/20 px-6 py-10 md:border-r md:border-b-0 md:px-8 md:py-12"
                >
                    <span
                        class="inline-flex border border-foreground/20 px-3 py-1 text-xs font-bold uppercase tracking-[0.08em]"
                    >
                        Minimal focus tools for Chrome
                    </span>
                    <h1
                        class="mt-6 text-5xl font-bold md:text-6xl"
                    >
                        Block distractions without fighting your browser.
                    </h1>
                    <p
                        class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground"
                    >
                        Prohibeo helps you block websites, schedule focused
                        time, and hide the noisy parts of sites like YouTube so
                        you can stay on task.
                    </p>
                    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                        <Button href="#install" size="lg">
                            See install options
                        </Button>
                        <Button href="/blog/" size="lg" variant="secondary">
                            Read the blog
                        </Button>
                    </div>
                </div>

                <div class="px-6 py-10 md:px-8 md:py-12">
                    <div
                        class="h-full border border-foreground/20 p-5 md:p-6"
                        aria-label="Prohibeo interface preview"
                    >
                        <div class="mb-4 flex gap-1.5">
                            <span class="h-3 w-3 bg-red-500"></span>
                            <span class="h-3 w-3 bg-yellow-400"></span>
                            <span class="h-3 w-3 bg-green-500"></span>
                        </div>
                        <div class="grid border border-foreground/20">
                            <div class="p-5">
                                <strong class="block text-base"
                                    >youtube.com</strong
                                >
                                <p
                                    class="mt-2 text-sm leading-6 text-muted-foreground"
                                >
                                    Scheduled blocking on weekdays, 9am to 5pm
                                </p>
                            </div>
                            <div class="border-t border-foreground/20 p-5">
                                <strong class="block text-base"
                                    >Hide distracting sections</strong
                                >
                                <ul
                                    class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-muted-foreground"
                                >
                                    <li>Hide comments</li>
                                    <li>Hide home page suggestions</li>
                                    <li>Hide shorts</li>
                                    <li>Hide video page suggestions</li>
                                </ul>
                            </div>
                            <div class="border-t border-foreground/20 p-5">
                                <strong class="block text-base"
                                    >Custom selectors</strong
                                >
                                <p
                                    class="mt-2 text-sm leading-6 text-muted-foreground"
                                >
                                    Add your own CSS selectors for any site you
                                    want to clean up.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div
                class="grid grid-cols-1 border-t border-foreground/20 pl-px pt-px md:grid-cols-3"
            >
                <GridBox>
                    <strong class="mb-2 block text-2xl tracking-[-0.04em]"
                        >2 modes</strong
                    >
                    <span class="text-sm leading-6 text-muted-foreground">
                        Always block or scheduled blocking
                    </span>
                </GridBox>
                <GridBox>
                    <strong class="mb-2 block text-2xl tracking-[-0.04em]"
                        >Fine control</strong
                    >
                    <span class="text-sm leading-6 text-muted-foreground">
                        Hide comments, shorts, sidebars, and more
                    </span>
                </GridBox>
                <GridBox>
                    <strong class="mb-2 block text-2xl tracking-[-0.04em]"
                        >Local-first</strong
                    >
                    <span class="text-sm leading-6 text-muted-foreground">
                        Settings stay in your Chrome profile
                    </span>
                </GridBox>
            </div>
        </section>

        <section class="border-t border-foreground/20" id="features">
            <SectionIntro>
                <SectionTitle>
                    Everything you need for a low-friction focus setup
                </SectionTitle>
                <p class="text-base leading-7 text-muted-foreground">
                    Prohibeo keeps the workflow simple: add a site, choose how
                    strict you want to be, and trim away the distracting
                    sections that still slip through.
                </p>
            </SectionIntro>
            <div class="grid grid-cols-1 pl-px pt-px md:grid-cols-3">
                <GridBox as="article">
                    <h3 class="mb-4 text-lg font-semibold">
                        Block entire sites
                    </h3>
                    <ul
                        class="list-disc space-y-3 pl-5 text-sm leading-6 text-muted-foreground"
                    >
                        <li>
                            Add domains like <InlineCode>youtube.com</InlineCode> or full URLs.
                        </li>
                        <li>Apply rules across subdomains automatically.</li>
                        <li>
                            Show a blocked-state screen when a site is fully
                            blocked.
                        </li>
                    </ul>
                </GridBox>
                <GridBox as="article">
                    <h3 class="mb-4 text-lg font-semibold">
                        Choose when blocking applies
                    </h3>
                    <ul
                        class="list-disc space-y-3 pl-5 text-sm leading-6 text-muted-foreground"
                    >
                        <li>
                            Switch between always-on and scheduled blocking.
                        </li>
                        <li>Select weekdays and focus hours.</li>
                        <li>
                            Keep rules flexible without adding extra complexity.
                        </li>
                    </ul>
                </GridBox>
                <GridBox as="article">
                    <h3 class="mb-4 text-lg font-semibold">
                        Hide the noisy parts instead
                    </h3>
                    <ul
                        class="list-disc space-y-3 pl-5 text-sm leading-6 text-muted-foreground"
                    >
                        <li>Use built-in YouTube section controls.</li>
                        <li>Add your own CSS selectors for custom cleanup.</li>
                        <li>
                            Keep the useful parts of a page while removing
                            rabbit holes.
                        </li>
                    </ul>
                </GridBox>
            </div>
        </section>

        <section class="border-t border-foreground/20" id="install">
            <div class="px-6 py-8 md:px-8 md:py-10">
                <div class="grid gap-4">
                    <div class="max-w-3xl">
                        <SectionTitle>Install Prohibeo</SectionTitle>
                        <p class="text-base leading-7 text-muted-foreground">
                            Prohibeo is currently easiest to try as a local
                            Chrome extension build. When a Chrome Web Store
                            listing is available, you can swap in that link here
                            without changing the site structure.
                        </p>
                    </div>
                    <ol
                        class="list-decimal space-y-3 pl-5 text-sm leading-6 text-muted-foreground"
                    >
                        <li>
                            Run <InlineCode>npm install</InlineCode> in the repo root.
                        </li>
                        <li>
                            Run <InlineCode>npm run build</InlineCode> to generate the extension in <InlineCode>dist/</InlineCode>.
                        </li>
                        <li>
                            Open <InlineCode>chrome://extensions</InlineCode> and enable Developer mode.
                        </li>
                        <li>
                            Choose <strong>Load unpacked</strong> and select the generated <InlineCode>dist/</InlineCode> folder.
                        </li>
                    </ol>
                </div>
            </div>
        </section>

        <section class="border-t border-foreground/20" id="privacy">
            <div class="px-6 py-8 md:px-8 md:py-10">
                <div class="grid gap-4">
                    <div class="max-w-3xl">
                        <SectionTitle>Privacy by default</SectionTitle>
                        <p class="text-base leading-7 text-muted-foreground">
                            Prohibeo stores your settings in <InlineCode>chrome.storage.local</InlineCode>,
                            so your website rules stay in your browser
                            profile on your machine.
                        </p>
                    </div>
                    <ul
                        class="list-disc space-y-3 pl-5 text-sm leading-6 text-muted-foreground"
                    >
                        <li>No account system</li>
                        <li>No billing or upgrade flow</li>
                        <li>No cloud sync in the current version</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="border-t border-foreground/20">
            <SectionIntro>
                <SectionTitle>Latest from the blog</SectionTitle>
                <p class="text-base leading-7 text-muted-foreground">
                    Use MDX posts for product updates, focus tips, release
                    notes, or Chrome Web Store launch announcements.
                </p>
            </SectionIntro>
            {latestPost && (
                <div class="grid grid-cols-1 pl-px pt-px">
                    <GridBox as="article">
                        <time
                            class="block text-sm text-muted-foreground"
                            datetime={latestPost.data.publishDate.toISOString()}
                        >
                            {latestPost.data.publishDate.toLocaleDateString("en-US", {
                                month: "long",
                                day: "numeric",
                                year: "numeric",
                            })}
                        </time>
                        <h3 class="mt-3 mb-3 text-lg font-semibold">
                            <a href={`/blog/${latestPost.id}/`}>{latestPost.data.title}</a>
                        </h3>
                        <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
                            {latestPost.data.description}
                        </p>
                    </GridBox>
                </div>
            )}
        </section>
    </main>
</BaseLayout>
