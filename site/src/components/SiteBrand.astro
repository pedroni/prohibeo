---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a class={`inline-flex items-center gap-3 text-base font-extrabold tracking-[-0.03em] ${className}`} href="/">
  <img
    src="/logo.svg"
    alt=""
    aria-hidden="true"
    class="h-10 w-10 border border-border"
  />
  <span>Prohibeo</span>
</a>
