---
import ChromeInstallLink from "./ChromeInstallLink.astro";
import GitHubLink from "./GitHubLink.astro";
import SiteBrand from "./SiteBrand.astro";
import SponsorHeartLink from "./SponsorHeartLink.astro";
---

<footer class="border-t border-border">
    <div
        class="grid gap-8 px-6 py-8 items-center md:grid-cols-[minmax(0,1fr)_auto] md:gap-12 md:px-8"
    >
        <div class="flex max-w-xl flex-col gap-4">
            <SiteBrand class="w-fit" />
            <p class="max-w-xl text-sm leading-6 text-muted-foreground">
                Prohibeo is an independent project built and maintained in the
                open. It is free to use, and if it helps you, a little support
                goes a long way.
            </p>
            <div
                class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground"
            >
                <span>One-time support is always appreciated</span>
                <SponsorHeartLink showText={true} />
            </div>
        </div>
        <div class="flex flex-col gap-4 text-sm md:items-end md:text-right">
            <div
                class="flex flex-wrap items-center gap-x-5 gap-y-3 md:justify-end"
            >
                <a href="/blog/">Blog</a>
                <a href="https://github.com/pedroni/prohibeo/issues/new/choose"
                    >Contact</a
                >
            </div>
            <div class="flex flex-wrap items-center gap-4 md:justify-end">
                <GitHubLink />
                <ChromeInstallLink class="font-semibold" />
            </div>
        </div>
    </div>
</footer>
