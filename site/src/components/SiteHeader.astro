---
import ChromeInstallLink from './ChromeInstallLink.astro';
import GitHubLink from './GitHubLink.astro';
import SiteBrand from './SiteBrand.astro';
import SponsorHeartLink from './SponsorHeartLink.astro';

const navItemClass =
  'border-t border-foreground/20 px-6 py-3 transition-colors hover:bg-foreground/20 md:border-t-0 md:border-l md:border-foreground/20 md:px-5 md:py-0';
---

<header class="border-b border-foreground/20">
  <div class="flex w-full flex-col md:flex-row md:items-stretch md:justify-between">
    <SiteBrand class="px-6 py-5 md:px-8" />
    <nav
      class="flex flex-col border-t border-foreground/20 text-sm md:flex-row md:self-stretch md:border-t-0"
      aria-label="Primary"
    >
      <a class={`flex items-center ${navItemClass}`} href="/blog/">Blog</a>
      <GitHubLink class={navItemClass} />
      <SponsorHeartLink class={navItemClass} showText={true} />
      <ChromeInstallLink class={`font-semibold ${navItemClass}`} />
    </nav>
  </div>
</header>
